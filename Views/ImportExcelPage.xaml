<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SecureBird_Data_Store.ViewModels"
             xmlns:models="clr-namespace:SecureBird_Data_Store.Models"
             x:Class="SecureBird_Data_Store.Views.ImportExcelPage"
             x:DataType="vm:ImportExcelViewModel"
             Title="Import Excel">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0" Padding="16,12" BackgroundColor="#217346" Spacing="10">
            <Label Text="Import from Excel" FontSize="20" FontAttributes="Bold"
                   TextColor="White" VerticalOptions="Center"/>
            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="White" VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="16" Spacing="14">

                <!-- File picker -->
                <Border Padding="16" StrokeShape="RoundRectangle 8" Stroke="{StaticResource Gray200}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Step 1 — Select Excel File" FontSize="15" FontAttributes="Bold"/>
                        <Button Text="Browse for .xlsx file..." Command="{Binding PickFileCommand}"
                                BackgroundColor="#217346" TextColor="White" CornerRadius="6"
                                HorizontalOptions="Start" Padding="14,8"/>
                        <Label Text="{Binding FileName}" FontSize="13" FontAttributes="Bold"
                               TextColor="{StaticResource Tertiary}"
                               IsVisible="{Binding FileName, Converter={StaticResource IsNotNullOrEmptyConverter}}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Profile section -->
                <Border Padding="14" StrokeShape="RoundRectangle 8"
                        Stroke="{StaticResource Secondary}" BackgroundColor="#F8F6FF"
                        IsVisible="{Binding SheetConfigs.Count, Converter={StaticResource IsNotZeroConverter}}">
                    <VerticalStackLayout Spacing="10">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <VerticalStackLayout Grid.Column="0" Spacing="1">
                                <Label Text="Import Profiles" FontSize="14" FontAttributes="Bold"
                                       TextColor="{StaticResource Tertiary}"/>
                                <Label Text="{Binding LoadedProfile.Name, StringFormat='Loaded: {0}'}"
                                       FontSize="11" TextColor="{StaticResource Gray500}"
                                       IsVisible="{Binding LoadedProfile, Converter={StaticResource IsNotNullConverter}}"/>
                                <Label Text="No profile loaded" FontSize="11" TextColor="{StaticResource Gray400}"
                                       IsVisible="{Binding LoadedProfile, Converter={StaticResource IsNullConverter}}"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="Save Profile"
                                    Command="{Binding SaveProfileCommand}"
                                    BackgroundColor="{StaticResource Secondary}"
                                    TextColor="{StaticResource Tertiary}"
                                    CornerRadius="6" Padding="12,6" FontSize="12"/>
                        </Grid>

                        <CollectionView ItemsSource="{Binding AvailableProfiles}"
                                        IsVisible="{Binding AvailableProfiles.Count, Converter={StaticResource IsNotZeroConverter}}"
                                        MaximumHeightRequest="160">
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:ImportProfile">
                                    <Grid ColumnDefinitions="*,Auto" Padding="4,6">
                                        <VerticalStackLayout Grid.Column="0" Spacing="1">
                                            <Label Text="{Binding Name}" FontSize="13" FontAttributes="Bold"/>
                                            <Label Text="{Binding Summary}" FontSize="11"
                                                   TextColor="{StaticResource Gray400}"/>
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="Load"
                                                FontSize="12" CornerRadius="4" Padding="10,4"
                                                BackgroundColor="{StaticResource Tertiary}"
                                                TextColor="White"
                                                CommandParameter="{Binding .}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:ImportExcelViewModel}}, Path=ApplyProfileCommand}"/>
                                    </Grid>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                        <Label Text="No saved profiles yet. Configure the sheets below and click Save Profile."
                               FontSize="11" TextColor="{StaticResource Gray400}" FontAttributes="Italic"
                               IsVisible="{Binding AvailableProfiles.Count, Converter={StaticResource IsZeroConverter}}"/>
                    </VerticalStackLayout>
                </Border>

                <!-- Sheet configuration -->
                <VerticalStackLayout
                    IsVisible="{Binding SheetConfigs.Count, Converter={StaticResource IsNotZeroConverter}}"
                    Spacing="10">

                    <Label Text="Step 2 — Configure Each Sheet" FontSize="15" FontAttributes="Bold"
                           Margin="0,4,0,0"/>
                    <Label FontSize="12" TextColor="{StaticResource Gray500}"
                           Text="Check the sheets to import. Optionally link each sheet's rows to a parent record from existing data — this builds your hierarchy."/>

                    <CollectionView ItemsSource="{Binding SheetConfigs}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:SheetImportConfig">
                                <Border Margin="0,4" Padding="14" StrokeShape="RoundRectangle 8"
                                        Stroke="{StaticResource Gray200}">
                                    <VerticalStackLayout Spacing="10">

                                        <!-- Sheet header -->
                                        <Grid ColumnDefinitions="Auto,*">
                                            <CheckBox Grid.Column="0" IsChecked="{Binding Include}"
                                                      VerticalOptions="Center"/>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                                                <Label Text="{Binding SheetName}" FontSize="14" FontAttributes="Bold"/>
                                                <Label Text="{Binding SheetSummary}" FontSize="11"
                                                       TextColor="{StaticResource Gray400}"/>
                                            </VerticalStackLayout>
                                        </Grid>

                                        <!-- Config (only when included) -->
                                        <VerticalStackLayout IsVisible="{Binding Include}" Spacing="8"
                                                             Margin="8,0,0,0">

                                            <!-- Structure mode -->
                                            <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="6">
                                                <Label Grid.Column="0" Text="Structure:"
                                                       FontSize="12" VerticalOptions="Center"
                                                       TextColor="{StaticResource Gray600}"/>
                                                <RadioButton Grid.Column="1" Content="New"
                                                             IsChecked="{Binding CreateNew}"
                                                             GroupName="{Binding SheetName}"/>
                                                <RadioButton Grid.Column="2" Content="Existing"
                                                             IsChecked="{Binding CreateNew, Converter={StaticResource InvertedBoolConverter}}"
                                                             GroupName="{Binding SheetName}"/>
                                            </Grid>

                                            <!-- New name -->
                                            <Entry IsVisible="{Binding CreateNew}"
                                                   Text="{Binding StructureName}"
                                                   Placeholder="Structure name" FontSize="13"/>

                                            <!-- Existing picker -->
                                            <Picker IsVisible="{Binding CreateNew, Converter={StaticResource InvertedBoolConverter}}"
                                                    ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:ImportExcelViewModel}}, Path=ExistingStructures}"
                                                    SelectedItem="{Binding ExistingStructure}"
                                                    ItemDisplayBinding="{Binding Name}"
                                                    Title="Select existing structure"
                                                    FontSize="13"/>

                                            <!-- Parent toggle -->
                                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                <CheckBox Grid.Column="0" IsChecked="{Binding HasParent}"
                                                          VerticalOptions="Center"/>
                                                <Label Grid.Column="1"
                                                       Text="Link all rows to a parent record (builds hierarchy)"
                                                       FontSize="12" VerticalOptions="Center"
                                                       TextColor="{StaticResource Gray600}"/>
                                            </Grid>

                                            <!-- Parent pickers -->
                                            <VerticalStackLayout IsVisible="{Binding HasParent}" Spacing="6"
                                                                 Margin="8,0,0,0">
                                                <Label Text="Parent structure:" FontSize="11"
                                                       TextColor="{StaticResource Gray500}"/>
                                                <Picker
                                                    ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:ImportExcelViewModel}}, Path=ExistingStructures}"
                                                    SelectedItem="{Binding ParentStructure}"
                                                    ItemDisplayBinding="{Binding Name}"
                                                    Title="Pick parent structure"
                                                    FontSize="13"/>

                                                <Label Text="Parent record:" FontSize="11"
                                                       TextColor="{StaticResource Gray500}"
                                                       IsVisible="{Binding AvailableParentRecords.Count, Converter={StaticResource IsNotZeroConverter}}"/>
                                                <Picker
                                                    IsVisible="{Binding AvailableParentRecords.Count, Converter={StaticResource IsNotZeroConverter}}"
                                                    ItemsSource="{Binding AvailableParentRecords}"
                                                    SelectedItem="{Binding SelectedParentRecord}"
                                                    ItemDisplayBinding="{Binding DisplayName}"
                                                    Title="Pick parent record"
                                                    FontSize="13"/>

                                                <Label IsVisible="{Binding SelectedParentRecord, Converter={StaticResource IsNotNullConverter}}"
                                                       Text="{Binding ParentRecordLabel, StringFormat='Parent: {0}'}"
                                                       FontSize="12" TextColor="#217346" FontAttributes="Italic"/>
                                            </VerticalStackLayout>

                                        </VerticalStackLayout>
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                </VerticalStackLayout>

                <!-- Success -->
                <Border Padding="20" StrokeShape="RoundRectangle 8" Stroke="#217346"
                        BackgroundColor="#F0FFF4" IsVisible="{Binding ImportComplete}">
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="Import Complete!" FontSize="18" FontAttributes="Bold"
                               TextColor="#217346" HorizontalOptions="Center"/>
                        <Label Text="{Binding ImportedStructures, StringFormat='{0} structures created'}"
                               FontSize="14" HorizontalOptions="Center"/>
                        <Label Text="{Binding ImportedRecords, StringFormat='{0} records imported'}"
                               FontSize="14" HorizontalOptions="Center"/>
                        <Label Text="Open Data Hierarchy to explore the tree."
                               FontSize="12" TextColor="{StaticResource Gray500}"
                               HorizontalOptions="Center" Margin="0,4,0,0"/>
                        <Button Text="Import Another File" Command="{Binding ResetCommand}"
                                BackgroundColor="#217346" TextColor="White" CornerRadius="6"
                                HorizontalOptions="Center" Padding="14,8" Margin="0,8,0,0"/>
                    </VerticalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Bottom bar -->
        <Grid Grid.Row="2" Padding="16,10" BackgroundColor="{StaticResource Gray100}"
              ColumnDefinitions="*,Auto"
              IsVisible="{Binding ImportComplete, Converter={StaticResource InvertedBoolConverter}}">
            <Label Grid.Column="0" Text="{Binding StatusMessage}"
                   TextColor="{StaticResource Gray600}" VerticalOptions="Center" FontSize="13"/>
            <Button Grid.Column="1" Text="Import Selected Sheets"
                    Command="{Binding ImportCommand}"
                    BackgroundColor="#217346" TextColor="White" CornerRadius="6" Padding="16,8"
                    IsEnabled="{Binding IsNotBusy}"
                    IsVisible="{Binding SheetConfigs.Count, Converter={StaticResource IsNotZeroConverter}}"/>
        </Grid>
    </Grid>
</ContentPage>
