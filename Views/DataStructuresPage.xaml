<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SecureBird_Data_Store.ViewModels"
             xmlns:models="clr-namespace:SecureBird_Data_Store.Models"
             x:Class="SecureBird_Data_Store.Views.DataStructuresPage"
             x:DataType="vm:DataStructuresViewModel"
             Title="Data Structures">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Toolbar -->
        <HorizontalStackLayout Grid.Row="0" Padding="16,12" Spacing="8"
                               BackgroundColor="{StaticResource Primary}">
            <Label Text="Data Structures" FontSize="20" FontAttributes="Bold"
                   TextColor="White" VerticalOptions="Center" HorizontalOptions="StartAndExpand"/>
            <Button Text="+ New Structure" Command="{Binding NewStructureCommand}"
                    BackgroundColor="White" TextColor="{StaticResource Primary}"
                    CornerRadius="6" Padding="12,6"/>
        </HorizontalStackLayout>

        <Grid Grid.Row="1">

            <!-- Structure List -->
            <Grid IsVisible="{Binding IsEditing, Converter={StaticResource InvertedBoolConverter}}">
                <CollectionView ItemsSource="{Binding Structures}" Margin="0">
                    <CollectionView.EmptyView>
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="12">
                            <Label Text="No data structures yet." FontSize="16" TextColor="{StaticResource Gray500}"
                                   HorizontalOptions="Center"/>
                            <Label Text="Create one or import an Excel file." FontSize="13"
                                   TextColor="{StaticResource Gray400}" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:DataStructure">
                            <Border Margin="12,6" Padding="16" StrokeShape="RoundRectangle 8"
                                    Stroke="{StaticResource Gray200}">
                                <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto">
                                    <Label Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                                           FontSize="15" FontAttributes="Bold"/>
                                    <Label Grid.Row="1" Grid.Column="0" Text="{Binding Description}"
                                           FontSize="12" TextColor="{StaticResource Gray500}"
                                           IsVisible="{Binding Description, Converter={StaticResource IsNotNullConverter}}"/>
                                    <!-- Parent rule badge -->
                                    <Border Grid.Row="1" Grid.Column="0"
                                            IsVisible="{Binding DefaultParentRecordId, Converter={StaticResource IsNotNullConverter}}"
                                            Padding="5,2" StrokeShape="RoundRectangle 4"
                                            BackgroundColor="{StaticResource Secondary}" Stroke="Transparent"
                                            HorizontalOptions="Start" Margin="0,2,0,0">
                                        <Label Text="default parent set" FontSize="10"
                                               TextColor="{StaticResource Tertiary}"/>
                                    </Border>
                                    <Label Grid.Row="0" Grid.Column="0" Grid.RowSpan="2"
                                           Text="{Binding Fields.Count, StringFormat='{0} fields'}"
                                           FontSize="11" TextColor="{StaticResource Gray400}"
                                           HorizontalOptions="End" VerticalOptions="Center" Margin="0,0,8,0"/>
                                    <Button Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                            Text="Records" FontSize="12"
                                            BackgroundColor="{StaticResource Primary}"
                                            TextColor="White"
                                            CornerRadius="4" Padding="10,4" Margin="4,0"
                                            CommandParameter="{Binding .}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DataStructuresViewModel}}, Path=ViewRecordsAsyncCommand}"/>
                                    <Button Grid.Row="0" Grid.Column="2" Grid.RowSpan="2"
                                            Text="Edit" FontSize="12"
                                            BackgroundColor="{StaticResource Secondary}"
                                            TextColor="{StaticResource Tertiary}"
                                            CornerRadius="4" Padding="10,4" Margin="4,0"
                                            CommandParameter="{Binding .}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DataStructuresViewModel}}, Path=EditStructureAsyncCommand}"/>
                                    <Button Grid.Row="0" Grid.Column="3" Grid.RowSpan="2"
                                            Text="Delete" FontSize="12"
                                            BackgroundColor="#FFEEEE" TextColor="Red"
                                            CornerRadius="4" Padding="10,4" Margin="4,0"
                                            CommandParameter="{Binding .}"
                                            Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DataStructuresViewModel}}, Path=DeleteCommand}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </Grid>

            <!-- Editor Panel -->
            <ScrollView IsVisible="{Binding IsEditing}">
                <VerticalStackLayout Padding="16" Spacing="12">
                    <Label Text="{Binding SelectedStructure, Converter={StaticResource NullToStringConverter},
                           ConverterParameter='New Structure|Edit Structure'}"
                           FontSize="18" FontAttributes="Bold"/>

                    <Label Text="Name *" FontSize="13" FontAttributes="Bold"/>
                    <Entry Text="{Binding EditName}" Placeholder="Structure name"/>

                    <Label Text="Description" FontSize="13" FontAttributes="Bold"/>
                    <Entry Text="{Binding EditDescription}" Placeholder="Optional description"/>

                    <!-- Default Parent Rule (Option 3) -->
                    <Border Padding="14" StrokeShape="RoundRectangle 8"
                            Stroke="{StaticResource Secondary}" BackgroundColor="#F8F6FF"
                            Margin="0,4,0,0">
                        <VerticalStackLayout Spacing="10">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                <CheckBox Grid.Column="0" IsChecked="{Binding HasDefaultParent}"
                                          VerticalOptions="Center"/>
                                <VerticalStackLayout Grid.Column="1" Spacing="1">
                                    <Label Text="Default Parent Rule" FontSize="13" FontAttributes="Bold"
                                           TextColor="{StaticResource Tertiary}"/>
                                    <Label Text="All records in this structure automatically get this parent on import."
                                           FontSize="11" TextColor="{StaticResource Gray500}"/>
                                </VerticalStackLayout>
                            </Grid>

                            <VerticalStackLayout IsVisible="{Binding HasDefaultParent}" Spacing="8"
                                                 Margin="8,0,0,0">
                                <Label Text="Parent structure:" FontSize="12"
                                       TextColor="{StaticResource Gray600}"/>
                                <Picker ItemsSource="{Binding Structures}"
                                        SelectedItem="{Binding DefaultParentStructure}"
                                        ItemDisplayBinding="{Binding Name}"
                                        Title="Pick a structure" FontSize="13"/>

                                <Label Text="Default parent record:" FontSize="12"
                                       TextColor="{StaticResource Gray600}"
                                       IsVisible="{Binding DefaultParentRecords.Count, Converter={StaticResource IsNotZeroConverter}}"/>
                                <Picker ItemsSource="{Binding DefaultParentRecords}"
                                        SelectedItem="{Binding DefaultParentRecord}"
                                        Title="Pick the default parent record"
                                        FontSize="13"
                                        IsVisible="{Binding DefaultParentRecords.Count, Converter={StaticResource IsNotZeroConverter}}">
                                    <Picker.ItemDisplayBinding>
                                        <Binding Path="." Converter="{StaticResource RecordDisplayConverter}"/>
                                    </Picker.ItemDisplayBinding>
                                </Picker>

                                <Label IsVisible="{Binding DefaultParentRecord, Converter={StaticResource IsNotNullConverter}}"
                                       Text="{Binding DefaultParentLabel, StringFormat='Rule: all new records get this parent: {0}'}"
                                       FontSize="12" TextColor="{StaticResource Tertiary}" FontAttributes="Italic"/>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Fields -->
                    <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                        <Label Text="Fields" FontSize="15" FontAttributes="Bold" VerticalOptions="Center"/>
                        <Button Grid.Column="1" Text="+ Add Field" Command="{Binding AddFieldCommand}"
                                BackgroundColor="{StaticResource Secondary}" TextColor="{StaticResource Tertiary}"
                                CornerRadius="4" Padding="10,4" FontSize="12"/>
                    </Grid>

                    <CollectionView ItemsSource="{Binding EditFields}">
                        <CollectionView.ItemTemplate>
                            <DataTemplate x:DataType="models:FieldDefinition">
                                <Border Margin="0,4" Padding="12" StrokeShape="RoundRectangle 6"
                                        Stroke="{StaticResource Gray200}" BackgroundColor="{StaticResource Gray100}">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto" RowDefinitions="Auto,Auto"
                                          ColumnSpacing="8" RowSpacing="6">
                                        <Entry Grid.Row="0" Grid.Column="0" Text="{Binding Name}"
                                               Placeholder="Field name" FontSize="13"/>
                                        <Picker Grid.Row="0" Grid.Column="1" SelectedItem="{Binding Type}"
                                                ItemsSource="{Binding Source={RelativeSource AncestorType={x:Type vm:DataStructuresViewModel}}, Path=FieldTypes}"
                                                FontSize="13" MinimumWidthRequest="90"/>
                                        <CheckBox Grid.Row="0" Grid.Column="2" IsChecked="{Binding Required}"
                                                  VerticalOptions="Center"/>
                                        <Label Grid.Row="0" Grid.Column="2" Text="Req" FontSize="10"
                                               VerticalOptions="End" HorizontalOptions="Center" Margin="0,0,0,-2"/>
                                        <Button Grid.Row="0" Grid.Column="3" Text="✕" FontSize="12"
                                                BackgroundColor="Transparent" TextColor="Red"
                                                Padding="4" WidthRequest="32"
                                                CommandParameter="{Binding .}"
                                                Command="{Binding Source={RelativeSource AncestorType={x:Type vm:DataStructuresViewModel}}, Path=RemoveFieldCommand}"/>
                                        <Entry Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3"
                                               Text="{Binding DefaultValue}" Placeholder="Default value (optional)"
                                               FontSize="12"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Export: Prompt / Completion mapping -->
                    <Border IsVisible="{Binding EditFields.Count, Converter={StaticResource IsNotZeroConverter}}"
                            Padding="14" StrokeShape="RoundRectangle 8"
                            Stroke="#aaaacc" BackgroundColor="#f0f0ff" Margin="0,4,0,0">
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Export — Prompt / Completion Mapping" FontSize="13"
                                   FontAttributes="Bold" TextColor="#16213e"/>
                            <Label Text="Designate which fields are the prompt and completion when exporting for fine-tuning. Optional — you can also set this at export time."
                                   FontSize="11" TextColor="{StaticResource Gray500}"/>
                            <Label Text="Prompt field:" FontSize="12"/>
                            <Picker ItemsSource="{Binding EditFields}"
                                    SelectedItem="{Binding EditPromptField}"
                                    ItemDisplayBinding="{Binding Name}"
                                    Title="None" FontSize="13"/>
                            <Label Text="Completion field:" FontSize="12"/>
                            <Picker ItemsSource="{Binding EditFields}"
                                    SelectedItem="{Binding EditCompletionField}"
                                    ItemDisplayBinding="{Binding Name}"
                                    Title="None" FontSize="13"/>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Status / Action Bar -->
        <Grid Grid.Row="2" Padding="16,10" BackgroundColor="{StaticResource Gray100}"
              ColumnDefinitions="*,Auto,Auto">
            <Label Grid.Column="0" Text="{Binding StatusMessage}" TextColor="{StaticResource Gray600}"
                   VerticalOptions="Center" FontSize="13"/>
            <Button Grid.Column="1" Text="Cancel" Command="{Binding CancelCommand}"
                    IsVisible="{Binding IsEditing}"
                    BackgroundColor="{StaticResource Gray200}" TextColor="{StaticResource Gray600}"
                    CornerRadius="6" Padding="14,6" Margin="0,0,8,0"/>
            <Button Grid.Column="2" Text="Save Structure" Command="{Binding SaveCommand}"
                    IsVisible="{Binding IsEditing}"
                    BackgroundColor="{StaticResource Primary}" TextColor="White"
                    CornerRadius="6" Padding="14,6"/>
        </Grid>

    </Grid>
</ContentPage>
